# --- 核心模型接入 (Core LLM) ---
# 建议统一使用 TA_ 前缀，同时也兼容 OPENAI_API_KEY / OPENAI_BASE_URL
TA_API_KEY=
TA_BASE_URL=https://api.openai.com/v1
TA_LLM_PROVIDER=openai

# 模型名配置 (默认已提供常用值)
TA_LLM_QUICK=gpt-4o-mini
TA_LLM_DEEP=gpt-4o

# LLM SDK 级重试次数。
# 适合 OpenAI 兼容上游偶发的流式断连；默认 1，建议保持在 0-2 之间。
# TA_LLM_MAX_RETRIES=1

# 单个 horizon 分析在遇到 Connection error / incomplete chunked read 等瞬时错误时，
# 后端允许自动重跑的次数；默认 1，避免一次上游抖动直接让整单分析失败。
# TA_HORIZON_TRANSIENT_RETRIES=1

# --- 安全密钥 (Security) ---
# 用于加密用户 API Key 和签发 JWT，生产环境必须设置！
# 生成方式: openssl rand -base64 32
# 首次设置时，系统会自动将已有数据从默认密钥迁移到新密钥。
# TA_APP_SECRET_KEY=

# --- 进阶可选配置 (Advanced Optional) ---
# 提示词语言 (auto / zh / en)，默认 zh
# TA_LANGUAGE=zh

# 运行日志追踪 (1 开启 / 0 关闭)，默认 1
# TA_TRACE=1

# 辩论与风险讨论轮数 (1-5)，默认 1
# TA_MAX_DEBATE=1
# TA_MAX_RISK=1

# --- VLM 截图识别 (Vision Language Model) ---
# 用于持仓截图识别，默认使用智谱 glm-4.6v-flash（免费）
# TA_VLM_API_KEY=你的智谱API Key
# TA_VLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# TA_VLM_MODEL=glm-4.6v-flash

# --- 邮件服务 (Email/SMTP) ---
# 仅在需要开启邮箱验证码登录时配置
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=465
# MAIL_USER=你的邮箱
# MAIL_PASS=你的授权码
# MAIL_FROM=发件人名称
# MAIL_SSL=1

# 兼容说明: 系统自动识别 TA_ 前缀变量。
# 若需修改默认行为，取消上述注释并填值即可。
