# --- 核心模型接入 (Core LLM) ---
# 建议统一使用 TA_ 前缀，同时也兼容 OPENAI_API_KEY / OPENAI_BASE_URL
TA_API_KEY=
TA_BASE_URL=https://api.openai.com/v1

# 模型名配置 (默认已提供常用值)
TA_LLM_QUICK=gpt-4o-mini
TA_LLM_DEEP=gpt-4o

# --- 进阶可选配置 (Advanced Optional) ---
# 提示词语言 (auto / zh / en)，默认 zh
# TA_LANGUAGE=zh

# 运行日志追踪 (1 开启 / 0 关闭)，默认 1
# TA_TRACE=1

# 辩论与风险讨论轮数 (1-5)，默认 1
# TA_MAX_DEBATE=1
# TA_MAX_RISK=1

# --- 邮件服务 (Email/SMTP) ---
# 仅在需要开启邮箱验证码登录时配置
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=465
# MAIL_USER=你的邮箱
# MAIL_PASS=你的授权码
# MAIL_FROM=发件人名称
# MAIL_SSL=1

# 兼容说明: 系统自动识别 TA_ 前缀变量。
# 若需修改默认行为，取消上述注释并填值即可。
