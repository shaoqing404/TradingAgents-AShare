# LLM Providers (set the one you use)
# OPENAI_API_KEY is also used by OpenAI-compatible backends (e.g. LongCat)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# Optional: OpenAI-compatible settings shown in CLI (preferred)
# Example for LongCat:
# OPENAI_BASE_URL=https://api.longcat.chat/openai/v1
# OPENAI_MODEL=LongCat-Flash-Chat
# OPENAI_MODELS=LongCat-Flash-Chat
OPENAI_BASE_URL=
OPENAI_MODEL=
OPENAI_MODELS=

# Backward-compatible aliases (still supported)
# OPENAI_COMPAT_NAME=LongCat
# OPENAI_COMPAT_BASE_URL=https://api.longcat.chat/openai/v1
# OPENAI_COMPAT_MODELS=LongCat-Flash-Chat
OPENAI_COMPAT_NAME=
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_MODELS=

# Optional runtime config for main.py example
LLM_PROVIDER=openai
QUICK_THINK_LLM=
DEEP_THINK_LLM=
MAX_DEBATE_ROUNDS=1
MAX_RISK_DISCUSS_ROUNDS=1

# Provider routing trace logs (applies to main.py and cli.main)
TRADINGAGENTS_PROVIDER_TRACE=1
