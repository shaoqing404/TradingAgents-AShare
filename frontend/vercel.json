{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "ignoreBuildStep": "if [ \"$VERCEL_GIT_COMMIT_REF\" = \"release\" ] || [ \"$VERCEL_GIT_COMMIT_REF\" = \"main\" ]; then exit 1; else exit 0; fi"
  },
  "framework": "vite",
  "rewrites": [
    {
      "source": "/v1/(.*)",
      "destination": "https://api.510168.xyz/v1/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://api.510168.xyz/uploads/$1"
    },
    {
      "source": "/((?!assets/|v1/|uploads/|vite.svg|favicon.ico).*)",
      "destination": "/index.html"
    }
  ]
}
